{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/yamk12nfu/ai-repo-ops/schemas/knowledge.schema.json",
  "title": "ai-repo-ops knowledge index",
  "description": "対象repoの .ai/local/knowledge/index.yaml を検証するauthoritative schema。本文はMarkdown、indexは根拠と検証commitだけを保持する。",
  "type": "object",
  "required": ["schema_version", "entries"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": 1
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "document", "verified_at_commit", "sources"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "document": {
            "type": "string",
            "minLength": 1
          },
          "verified_at_commit": {
            "type": "string",
            "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$"
          },
          "sources": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["path"],
              "additionalProperties": false,
              "properties": {
                "path": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    }
  }
}
